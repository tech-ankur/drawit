{"$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "generate": {
      "cache": false,
      "inputs": ["**/*.prisma"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build", "generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}